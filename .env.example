# Example .env (DO NOT COMMIT)
# Copy this file to .env and fill with real secrets for local development.

# Spring profile to activate
SPRING_PROFILES_ACTIVE=supabase

# Supabase Postgres JDBC URL (include sslmode=require for remote Supabase)
SUPABASE_DB_URL=jdbc:postgresql://<host>:5432/<database>?sslmode=require
SUPABASE_DB_USERNAME=<db_user>
SUPABASE_DB_PASSWORD=<db_password>

# Supabase project info (used for Auth/JWT validation)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_API_KEY=<anon-or-service-key>

# Optional: mail and third-party keys (example placeholders)
EMAIL_USERNAME=admin@ipscentir.com
EMAIL_PASSWORD=changeme
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
