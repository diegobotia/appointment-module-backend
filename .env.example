# Copiar a .env y completar con valores reales (no commitear .env)

# --- Spring ---
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# --- Base de datos (PostgreSQL local) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ipscentir_appointments
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_FLYWAY_ENABLED=true

# --- Módulo de autenticación JWT ---
# Secreto compartido con el módulo de facturación (billing) para validar tokens HS256
JWT_SECRET=copy-the-same-JWT_SECRET-from-billing-module

# URL base del módulo de autenticación (billing)
AUTH_MODULE_BASE_URL=http://localhost:8081

# Logs de diagnóstico de autenticación
SECURITY_AUTH_DIAGNOSTICS=true

# --- Seguridad n8n ---
N8N_API_KEY=change-this-in-production
N8N_BASE_PATH=/api/v1/integrations/n8n

# --- Integraciones externas ---
PATIENT_SERVICE_URL=http://localhost:8081
AFFILIATION_SERVICE_URL=http://external-system/affiliation
CLINICAL_SERVICE_URL=http://localhost:8083

# --- Notificaciones ---
NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_CREATED_ALERT_ENABLED=false
NOTIFICATIONS_CANCELLED_ALERT_ENABLED=false
NOTIFICATIONS_REMINDER_24H_ENABLED=true
NOTIFICATIONS_REMINDER_2H_ENABLED=false
NOTIFICATIONS_MAX_RETRY_ATTEMPTS=3

# Twilio (SMS / WhatsApp)
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# Resend (email)
RESEND_ENABLED=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Email SMTP (fallback)
EMAIL_USERNAME=admin@ipscentir.com
EMAIL_PASSWORD=changeme

# --- Terapia grupal ---
THERAPY_PENDING_GROUP_POLICY=RESCHEDULE
THERAPY_PENDING_GROUP_CUTOFF_MINUTES=120

# --- Formulario paciente ---
PATIENT_REGISTRATION_FORM_URL=https://citas.ipscentir.com/registro
