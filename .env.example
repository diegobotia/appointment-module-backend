# Copiar a .env y completar con valores reales (no commitear .env)
#
# CONFIGURACIÓN PARA POSTGRESQL DIRECTO (producción en servidor local):
#   SPRING_PROFILES_ACTIVE=prod
#   (usa application.yml + application-prod.yml, datasource vía SPRING_DATASOURCE_*)
#
# CONFIGURACIÓN PARA SUPABASE (alternativa):
#   SPRING_PROFILES_ACTIVE=prod,supabase
#   (usa además application-supabase.yml, datasource vía SUPABASE_DB_*)

# --- Spring ---
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# --- Base de datos PostgreSQL directa ---
# La BD ya existe en el servidor junto con el módulo de billing
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ipscentir_appointments
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_FLYWAY_ENABLED=true

# --- JWT (compartido con módulo de billing/facturación) ---
# DEBE ser el mismo JWT_SECRET que usa el módulo de billing para firmar/validar tokens HS256
JWT_SECRET=copy-the-same-JWT_SECRET-from-billing-module

# URL base del módulo de billing (solo para que el frontend sepa dónde redirigir login)
AUTH_MODULE_BASE_URL=http://<billing-host>:<billing-port>

# Logs de diagnóstico de autenticación (true solo para depuración)
SECURITY_AUTH_DIAGNOSTICS=false

# --- Seguridad n8n ---
N8N_API_KEY=change-this-in-production
N8N_BASE_PATH=/api/v1/integrations/n8n

# --- Integraciones externas ---
PATIENT_SERVICE_URL=http://<billing-host>:<billing-port>
AFFILIATION_SERVICE_URL=http://external-system/affiliation
CLINICAL_SERVICE_URL=http://<clinical-host>:<clinical-port>

# --- Notificaciones (opcional, deshabilitar si no se usa) ---
NOTIFICATIONS_ENABLED=false
NOTIFICATIONS_CREATED_ALERT_ENABLED=false
NOTIFICATIONS_CANCELLED_ALERT_ENABLED=false
NOTIFICATIONS_REMINDER_24H_ENABLED=false
NOTIFICATIONS_REMINDER_2H_ENABLED=false
NOTIFICATIONS_MAX_RETRY_ATTEMPTS=3

# Twilio (SMS / WhatsApp) — solo si NOTIFICATIONS_ENABLED=true
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# Resend (email) — solo si NOTIFICATIONS_ENABLED=true
RESEND_ENABLED=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Email SMTP (fallback)
EMAIL_USERNAME=admin@ipscentir.com
EMAIL_PASSWORD=changeme

# --- Terapia grupal ---
THERAPY_PENDING_GROUP_POLICY=RESCHEDULE
THERAPY_PENDING_GROUP_CUTOFF_MINUTES=120

# --- Formulario paciente ---
PATIENT_REGISTRATION_FORM_URL=https://citas.ipscentir.com/registro
